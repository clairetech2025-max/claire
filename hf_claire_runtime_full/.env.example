# Hugging Face Space secrets/config names only. Do not commit real values.

# Provider/model
CLAIRE_PROVIDER=nim
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
CLAIRE_LOCAL_LLM_URL=
LLM_BASE_URL=
CLAIRE_PROVIDER_TIMEOUT_SECONDS=180

# Runtime storage inside HF persistent storage, if enabled
CLAIRE_RUNTIME_DATA_DIR=/data/claire_runtime
CLAIRE_BASE_DIR=/app
CLAIRE_ORIGINAL_ARE_MEM_PATH=/data/claire_runtime/are/are_mem.jsonl
CLAIRE_STATE_DIR=/data/claire_runtime/claire_state
CLAIRE_MEMORY_VAULT_PATH=/data/claire_runtime/memory_vault.jsonl
CLAIRE_INGEST_SENTINEL_SPINE=/data/claire_runtime/silo_data/sentinel_spine.jsonl
CLAIRE_TRACE_PATH=/data/claire_runtime/traces/claire_runtime_traces.jsonl
CLAIRE_TRACE_DB_PATH=/data/claire_runtime/traces/claire_runtime_traces.db
ARE_URL=http://127.0.0.1:8002
LLM_URL=http://127.0.0.1:8080
INGEST_BASE_URL=http://127.0.0.1:8081
CLAIRE_ARE_INGEST_URL=http://127.0.0.1:8002/ingest
CLAIRE_GO_ADDR=127.0.0.1:8080

# Optional external services. Leave unset for initial migration unless approved.
COURTLISTENER_API_KEY=
COURTLISTENER_TOKEN=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
CAP_API_KEY=
OPENALEX_MAILTO=
SEMANTIC_SCHOLAR_API_KEY=
ARE_SPECTACLE_URL=
CLAIRE_ARE_INGEST_URL=
CLAIRE_INGEST_TOKEN=
CLAIRE_ADMIN_ACTION_TOKEN=
HANDSHAKE_BROKER_SECRET=
CLAIRE_ARE_HMAC_KEY=
CLAIRE_GOOGLE_OAUTH_TOKEN_JSON=
CLAIRE_GOOGLE_SERVICE_ACCOUNT_JSON=

# Safety defaults
CLAIRE_PUBLIC_DEMO_BUILD=0
CLAIRE_CREATOR_MODE_ENABLED=0
VERITAS_TRADING_MODE=paper
VERITAS_ENABLE_LIVE_TRADING=false
