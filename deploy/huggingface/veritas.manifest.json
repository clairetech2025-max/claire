{
  "schema_version": "claire-hf-deployment.v1",
  "application": "Veritas Legal",
  "space_id": "",
  "space_url": "",
  "sdk": "unknown until authenticated discovery",
  "expected_host": "0.0.0.0",
  "expected_port": 7860,
  "source_paths": [
    "../claire_repos/claire-veritas-legal"
  ],
  "entry_point": "web/app.py or Space-specific app.py",
  "startup_command": "python app.py",
  "health_endpoint": "/veritas/health or /health depending on Space adapter",
  "required_variable_names": [
    "VERITAS_DEMO_MODE",
    "VERITAS_PUBLIC_DEMO",
    "VERITAS_LLM_BASE_URL",
    "VERITAS_CONTEXT_SIZE"
  ],
  "required_secret_names": [],
  "persistent_state": {
    "demo matter": "rebuildable from GitHub sanitized fixture",
    "uploaded legal evidence": "prohibited in public Space by default",
    "matter databases": "ephemeral unless private persistent storage is explicitly configured",
    "indexes": "rebuildable from sanitized demo fixtures"
  },
  "exclude": [
    ".env",
    "*.env",
    ".git/",
    "*.key",
    "*.pem",
    "*.db",
    "*.sqlite",
    "*.log",
    "__pycache__/",
    ".pytest_cache/",
    "venv/",
    ".venv/",
    "uploads/",
    "evidence/",
    "private/",
    "memory/",
    "matter_data/",
    "runtime_logs/",
    "models/",
    "indexes/"
  ],
  "current_discovery": {
    "visibility": "not publicly visible under Blackstormhorse or Claire-Systems",
    "blocker": "Hugging Face authentication is required to identify private Veritas Space"
  }
}
