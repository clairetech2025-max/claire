FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml ./
COPY claire_are ./claire_are
COPY claire_vde ./claire_vde

RUN pip install --no-cache-dir -e .

EXPOSE 8030

CMD ["uvicorn", "claire_vde.api:app", "--host", "0.0.0.0", "--port", "8030"]
